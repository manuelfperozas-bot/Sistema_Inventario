<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="front_end.Panel_principal_Controller">

    <left>
        <VBox prefWidth="220.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="200.0">
                    <children>
                        <Label styleClass="sidebar-title" text="Invent Pro" />
                    </children>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </HBox>
                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button maxWidth="1.1797693134862315E308" mnemonicParsing="false" onAction="#btnInventario" text="📦 Inventario">
                            <styleClass>
                                <String fx:value="menu-button" />
                                <String fx:value="menu-button-active" />
                            </styleClass>
                        </Button>
                        <Button maxWidth="1.1797693134862315E308" mnemonicParsing="false" onAction="#btnRegCambios" styleClass="menu-button" text="⏱ Registro de cambios" />
                        <Button maxWidth="1.1797693134862315E308" mnemonicParsing="false" onAction="#btnSalVent" styleClass="menu-button" text="📤 Salidas / Ventas" />
                        <Button maxWidth="1.1797693134862315E308" mnemonicParsing="false" onAction="#btnReportes" styleClass="menu-button" text="📊 Reportes" />
                    </children>
                    <padding>
                        <Insets left="10.0" right="10.0" top="20.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0">
                    <children>
                        <TextField fx:id="txtBuscar" onKeyReleased="#txtBuscar_change" promptText="Buscar producto por nombre o categoría..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button fx:id="btnAgregar" alignment="CENTER" mnemonicParsing="false" onAction="#btnAgregar" text="+ Agregar">
                                    <styleClass>
                                        <String fx:value="btn" />
                                        <String fx:value="btn-primary" />
                                    </styleClass>
                                </Button>
                                <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#btnEditar" text="✏ Editar">
                                    <styleClass>
                                        <String fx:value="btn" />
                                        <String fx:value="btn-secondary" />
                                    </styleClass>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tablaProductos" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="312.79998475313187" text="Producto" />
                        <TableColumn fx:id="colCategoria" prefWidth="189.60003662109375" text="Categoría" />
                        <TableColumn fx:id="colStock" prefWidth="100.0" text="Stock" />
                  <TableColumn fx:id="colprecio" prefWidth="100.0" text="Precio" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="topbar" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Panel General de Inventario" />
                <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnTasaBCV" mnemonicParsing="false" onAction="#btnTasaBCV" prefHeight="32.0" prefWidth="160.0" styleClass="tasa-bcv-container" text="💵 BCV: ---,-- Bs." />
                    </children>
                    <padding>
                        <Insets right="25.0" />
                    </padding>
                </HBox>
            </children>
            <padding>
                <Insets left="25.0" />
            </padding>
        </HBox>
    </top>
    <stylesheets>
        <URL value="@Panel_principal.css" />
    </stylesheets>
</BorderPane>
